{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd america-main && npm run build",
    "rootDirectory": "america-main"
  },
  "deploy": {
    "startCommand": "cd america-main && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
